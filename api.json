          {
            "name": "from",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date-time"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Range start (UTC).",
              "title": "From"
            },
            "description": "Range start (UTC)."
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date-time"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Range end (UTC).",
              "title": "To"
            },
            "description": "Range end (UTC)."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 5000,
              "minimum": 1,
              "description": "Maximum points to return.",
              "default": 2000,
              "title": "Limit"
            },
            "description": "Maximum points to return."
          },
          {
            "name": "channel",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional channel filter.",
              "title": "Channel"
            },
            "description": "Optional channel filter."
          },
          {
            "name": "campaign",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional campaign filter.",
              "title": "Campaign"
            },
            "description": "Optional campaign filter."
          }
        ],
        "responses": {
          "200": {
            "description": "Minute KPI series for the selected period.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KpiSeries"
                }
              }
