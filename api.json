  "paths": {
    "/events/order": {
      "post": {
        "tags": [
          "ingest"
        ],
        "summary": "Publish order event",
        "description": "Validates order payload and publishes it to the Kafka orders topic. Returns accepted status with final event_id.",
        "operationId": "ingest_order_events_order_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderEvent"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Accepted status and event identifier.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ]
      }
    },
    "/events/session": {
      "post": {
        "tags": [
          "ingest"
        ],
        "summary": "Publish session event",
        "description": "Validates session payload and publishes it to the Kafka sessions topic. Returns accepted status with final event_id.",
        "operationId": "ingest_session_events_session_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionEvent"
              }
