            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ]
      }
    },
    "/kpi/latest": {
      "get": {
        "tags": [
          "kpi"
        ],
        "summary": "Get latest KPI point",
        "description": "Returns the latest aggregated KPI point for the selected bucket (minute or hour), with optional segmentation by channel/campaign.",
        "operationId": "kpi_latest_kpi_latest_get",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "bucket",
            "in": "query",
            "required": false,
            "schema": {
              "enum": [
                "minute",
                "hour"
              ],
              "type": "string",
              "description": "Aggregation bucket: minute or hour.",
              "default": "minute",
              "title": "Bucket"
            },
            "description": "Aggregation bucket: minute or hour."
          },
          {
            "name": "channel",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional channel filter.",
              "title": "Channel"
            },
            "description": "Optional channel filter."
          },
          {
            "name": "campaign",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional campaign filter.",
              "title": "Campaign"
            },
            "description": "Optional campaign filter."
          }
        ],
        "responses": {
          "200": {
            "description": "Latest KPI point and applied filters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KpiLatest"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
